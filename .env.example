# Delulu env example (current app usage)

# TMDb API (backend-only)
TMDB_API_KEY=your_tmdb_api_key
TMDB_READ_TOKEN=your_tmdb_read_token

# Algolia Search (backend-only runtime search)
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_SEARCH_KEY=your_algolia_search_key
ALGOLIA_INDEX_NAME=delulu_content

# Optional: used only by scripts/sync-algolia-index.mjs
ALGOLIA_ADMIN_KEY=
