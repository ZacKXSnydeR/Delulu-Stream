# Delulu environment template
# Put real secrets in `.env.local` (ignored by git).

# TMDb API (backend-only)
TMDB_API_KEY=
TMDB_READ_TOKEN=

# Algolia Search (backend-only runtime search)
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_KEY=
ALGOLIA_INDEX_NAME=delulu_content

# Needed only for sync script (server-side usage only)
ALGOLIA_ADMIN_KEY=
